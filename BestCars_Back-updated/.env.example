# Server
PORT=3001
NODE_ENV=development

# Postgres (Supabase or any Postgres)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public

# CORS (comma-separated list). Leave empty in dev to allow all.
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# Panel Auth (simple admin)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
JWT_SECRET=change-me-super-secret

# SendGrid (optional: forms will still be saved to DB if email fails)
SENDGRID_API_KEY=
FROM_EMAIL=dev@theaibusiness.com
RECIPIENT_EMAIL=dev@theaibusiness.com
